{
  "name": "shortcutype",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "node scripts/start.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "tsc -b --pretty false",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "benchmark": "vitest bench --run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "verify": "npm run lint && npm test && npm run test:e2e && npm run build && npm run benchmark && npm audit --audit-level=moderate",
    "verify:five": "node scripts/verify-five.mjs"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  }
}
